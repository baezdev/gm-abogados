---
import "../styles/global.css";
import "@fontsource/dm-sans";
import "@fontsource/playfair-display";
import { absoluteUrl, site } from "@/config/site";
import { faqPageJsonLd, legalServiceJsonLd } from "@/data/schema";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
}

const homeUrl = absoluteUrl("/");
const ogImageUrl = absoluteUrl(site.ogImagePath);
const legalLd = legalServiceJsonLd();
const faqLd = faqPageJsonLd();

const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  canonical = homeUrl,
  ogTitle = title,
  ogDescription = description,
  ogUrl = homeUrl,
} = Astro.props;
---

<!doctype html>
<html lang={site.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es-mx" href={homeUrl} />
    <link rel="alternate" hreflang="es" href={homeUrl} />

    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <meta name="geo.region" content={site.geo.region} />
    <meta name="geo.placename" content={site.geo.placename} />
    <meta name="geo.position" content={site.geo.position} />
    <meta name="ICBM" content={site.geo.icbm} />

    <meta name="author" content={site.author} />
    <meta name="copyright" content={site.copyright} />
    <meta name="language" content={site.languageMeta} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={site.localeOg} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterSite} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content={site.themeColor} />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content={site.themeColor}
    />

    <meta name="format-detection" content="telephone=yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={site.shortName} />

    <script type="application/ld+json" set:html={JSON.stringify(legalLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
