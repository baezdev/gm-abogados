---
interface Props {
  question: string;
  answer: string;
  index: number;
}

const { question, answer, index } = Astro.props;
const answerId = `faq-answer-${index}`;
const buttonId = `faq-button-${index}`;
---

<div class="gm-faq-item" data-index={index}>
  <button 
    class="gm-faq-question" 
    id={buttonId}
    aria-expanded="false" 
    aria-controls={answerId}
    data-target={answerId}
  >
    {question}
    <span class="gm-faq-icon">+</span>
  </button>
  <div 
    class="gm-faq-answer" 
    id={answerId}
    role="region" 
    aria-labelledby={buttonId}
  >
    <div class="gm-faq-answer-inner" set:html={answer} />
  </div>
</div>

<style>
  .gm-faq-item {
    border-bottom: 1px solid var(--border);
  }

  .gm-faq-question {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 1.5rem 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--white);
    transition: color 0.2s;
  }

  .gm-faq-question:hover {
    color: var(--gold2);
  }

  .gm-faq-icon {
    width: 24px;
    height: 24px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.9rem;
    color: var(--gold);
    transition: transform 0.3s, background 0.2s;
  }

  .gm-faq-item.open .gm-faq-icon {
    transform: rotate(45deg);
    background: rgba(201,168,76,.1);
  }

  .gm-faq-answer {
    overflow: hidden;
    transition: max-height 0.35s ease;
    max-height: 0;
  }

  .gm-faq-item.open .gm-faq-answer {
    max-height: var(--faq-height, 400px);
  }

  .gm-faq-answer-inner {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.75;
    padding-bottom: 1.5rem;
  }

  .gm-faq-answer-inner :global(strong) {
    color: var(--white);
    font-weight: 500;
  }
</style>

<script>
  function initFaq() {
    const items = document.querySelectorAll('.gm-faq-item');
    
    items.forEach(item => {
      const btn = item.querySelector('.gm-faq-question');
      const answer = item.querySelector('.gm-faq-answer');
      
      if (!btn || !answer) return;
      
      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        
        document.querySelectorAll('.gm-faq-item.open').forEach(el => {
          el.classList.remove('open');
          const b = el.querySelector('.gm-faq-question');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        } else {
          answer.style.maxHeight = '0';
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initFaq);
</script>
