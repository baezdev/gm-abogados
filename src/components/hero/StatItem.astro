---
interface Props {
  num: string;
  desc: string;
}

const { num, desc } = Astro.props;
---

<div class="gm-stat-item">
  <div class="gm-stat-num">{num}</div>
  <div class="gm-stat-desc">{desc}</div>
</div>

<style>
  .gm-stat-num {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .gm-stat-desc {
    font-size: 0.78rem;
    color: var(--gray);
    margin-top: 0.3rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
