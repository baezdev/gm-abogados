---
import GuaranteeItem from "./GuaranteeItem.astro";
import UrgencyPoint from "./UrgencyPoint.astro";

const guarantees = [
  {
    path: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    title: "Consulta gratuita y sin compromiso",
    description: "Evaluamos tu caso de despido injustificado en 30 minutos sin costo. Te decimos exactamente cuánto puedes recuperar.",
  },
  {
    path: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Solo pagas si ganamos tu caso",
    description: "Cero honorarios por adelantado. Trabajamos a porcentaje de éxito. Si no recuperas tu liquidación, no nos pagas nada.",
  },
  {
    path: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    title: "+150 casos ganados en CDMX",
    description: "Hemos recuperado millones de pesos para trabajadores. Desde 3 hasta 20 meses de salario en liquidaciones y prestaciones.",
  },
];

const urgencyPoints = [
  "<strong>NUNCA firmes</strong> tu renuncia voluntaria o finiquito sin asesoría legal. Una firma puede hacerte perder hasta 20 meses de salario.",
  "Tienes <strong>solo 2 meses</strong> desde tu despido para demandar. Después de 60 días naturales pierdes tu derecho legal.",
  "<strong>Consulta GRATIS en 24 horas.</strong> Te decimos exactamente cuánto puedes recuperar y cómo proceder.",
  "<strong>Cero pesos de anticipo.</strong> No pagas abogado, trámites ni costas judiciales hasta que recibas tu liquidación.",
];
---

<section class="gm-porque" id="porque">
  <div class="gm-container">
    <div class="gm-porque-grid">
      <div class="gm-porque-left reveal">
        <span class="section-label">Nuestras garantías</span>
        <h2>Por qué elegir GM Abogados</h2>
        <ul class="gm-porque-list">
          {guarantees.map((item) => (
            <GuaranteeItem 
              path={item.path}
              title={item.title}
              description={item.description}
            />
          ))}
        </ul>
      </div>

      <div class="gm-porque-right reveal">
        <div class="gm-urgency-box">
          <div class="gm-urgency-box-label">
            <svg
              viewBox="0 0 24 24"
              width="14"
              height="14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
            Urgente — Lee esto si te despidieron
          </div>
          <h3>Tienes solo 60 días para demandar tu liquidación</h3>
          <ul class="gm-urgency-points">
            {urgencyPoints.map((text) => (
              <UrgencyPoint text={text} />
            ))}
          </ul>
          <a href="#contacto" class="btn-hero">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
              <path
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Agendar Consulta Gratuita
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gm-porque {
    padding: 7rem clamp(1.5rem, 5vw, 4rem);
    background: var(--navy2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .gm-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .gm-porque-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .gm-porque-list {
    list-style: none;
    margin-top: 2.5rem;
  }

  .gm-urgency-box {
    background: var(--navy);
    border: 1px solid rgba(192, 57, 43, 0.4);
    border-radius: 6px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .gm-urgency-box::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--red);
  }

  .gm-urgency-box-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red2);
    margin-bottom: 1.25rem;
  }

  .gm-urgency-box h3 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    font-style: normal;
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }

  .gm-urgency-points {
    list-style: none;
    margin-bottom: 2rem;
  }

  @media (max-width: 900px) {
    .gm-porque-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
