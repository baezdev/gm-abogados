---
import ArrowR from "@/components/icons/ArrowR.astro";
import { slugToTitle } from "./types";

interface Props {
  relacionados: string[];
}

const { relacionados } = Astro.props;
---

<section class="sv-section sv-relacionados">
  <div class="sv-container">
    <div class="reveal">
      <span class="sv-section-label">Otros servicios</span>
      <h2>También podemos ayudarte con</h2>
    </div>
    <div class="sv-relacionados-grid">
      {
        relacionados.map((slug, index) => (
          <a
            href={`/servicios/${slug}`}
            class="sv-relacionado-card reveal"
            style={`transition-delay: ${index * 80}ms`}
          >
            <div class="sv-relacionado-title">{slugToTitle[slug]}</div>
            <div class="sv-relacionado-arrow">
              <ArrowR />
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sv-section {
    padding: 6rem clamp(1.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border, rgba(201, 168, 76, 0.18));
  }

  .sv-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .sv-section-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold, #c9a84c);
    margin-bottom: 0.75rem;
  }

  .sv-section h2 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .sv-relacionados-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .sv-relacionado-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--navy2, #111827);
    border: 1px solid var(--border, rgba(201, 168, 76, 0.18));
    border-radius: 8px;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .sv-relacionado-card:hover {
    border-color: rgba(201, 168, 76, 0.45);
    background: var(--navy3, #1e2a3b);
  }

  .sv-relacionado-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--white);
    line-height: 1.4;
  }

  .sv-relacionado-arrow {
    color: var(--gold, #c9a84c);
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .sv-relacionado-card:hover .sv-relacionado-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .sv-relacionados-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
