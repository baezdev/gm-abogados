---
import FaqItem from "@/components/faq/FaqItem.astro";
import type { ServiceFaq } from "./types";

interface Props {
  faqs: ServiceFaq[];
}

const { faqs } = Astro.props;
---

<section class="sv-section sv-faq">
  <div class="sv-container sv-faq-grid">
    <div class="sv-faq-left">
      <span class="sv-section-label">Preguntas frecuentes</span>
      <h2>Resolvemos tus dudas</h2>
      <p>
        Si tu pregunta no está aquí, agenda una consulta gratuita y te
        respondemos sin compromiso.
      </p>
      <a href="#contacto" class="btn-primary" style="margin-top:1.5rem;display:inline-block;">
        Hacer mi pregunta
      </a>
    </div>
    <div class="sv-faq-items">
      {
        faqs.map((faq, i) => (
          <FaqItem question={faq.q} answer={faq.a} index={i} />
        ))
      }
    </div>
  </div>
</section>

<style>
  .sv-section {
    padding: 6rem clamp(1.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border, rgba(201, 168, 76, 0.18));
  }

  .sv-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .sv-section-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold, #c9a84c);
    margin-bottom: 0.75rem;
  }

  .sv-section h2 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .sv-faq {
    background: var(--navy2, #111827);
  }

  .sv-faq-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .sv-faq-left p {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .sv-faq-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
